<?xml version="1.0"?>

<robot name="lekiwi_robot">

  <!-- ===================== -->
  <!-- Base Link             -->
  <!-- ===================== -->

  <link name="base_link">

    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.05"/>
      </geometry>
      <material name="base_color"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.15" length="0.05"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.01"
        ixy="0"
        ixz="0"
        iyy="0.01"
        iyz="0"
        izz="0.02"/>
    </inertial>

  </link>

  <!-- ===================== -->
  <!-- Wheel 1 Front         -->
  <!-- ===================== -->

  <link name="wheel_1">

    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
      <material name="wheel_color"/>
    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0002"/>
    </inertial>

  </link>

  <joint name="wheel_1_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_1"/>
    <origin xyz="0.12 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================== -->
  <!-- Wheel 2 Left Rear     -->
  <!-- ===================== -->

  <link name="wheel_2">

    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
      <material name="wheel_color"/>
    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0002"/>
    </inertial>

  </link>

  <joint name="wheel_2_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_2"/>
    <origin xyz="-0.06 0.104 0" rpy="0 0 2.0944"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================== -->
  <!-- Wheel 3 Right Rear    -->
  <!-- ===================== -->

  <link name="wheel_3">

    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
      <material name="wheel_color"/>
    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0002"/>
    </inertial>

  </link>

  <joint name="wheel_3_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_3"/>
    <origin xyz="-0.06 -0.104 0" rpy="0 0 -2.0944"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>
